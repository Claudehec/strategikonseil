{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install --legacy-peer-deps && npm run build",
    "nixpacks": {
      "buildImage": "node:18-alpine"
    }
  },
  "deploy": {
    "startCommand": "npx serve -s build -l $PORT",
    "healthcheckPath": "/"
  }
}
